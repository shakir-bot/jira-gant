{
  "name": "gantt-jira-local",
  "version": "1.0.0",
  "description": "Локальное веб-приложение: диаграмма Ганта с авторизацией в Jira Cloud",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "pkg ."
  },
  "dependencies": {
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "undici": "^6.27.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.21.0"
  },
  "pkg": {
    "assets": ["public/**/*"],
    "targets": ["node22-macos-x64", "node22-macos-arm64", "node22-win-x64"],
    "outputPath": "dist"
  }
}
